rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Public read for gallery images
    match /gallery/{folder}/{allPaths=**} {
      allow read: if true;
      allow write: if false;
    }

    // Deny everything else by default
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
